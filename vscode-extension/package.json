{
  "name": "vscode-extension",
  "displayName": "LIM Workspace",
  "description": "Embeds the LIM browser viewer and terminal REPL inside VS Code as a single dockable panel.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/statellm/lim"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:lim.workspace.start",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "resources/lim.png",
  "contributes": {
    "commands": [
      {
        "command": "lim.workspace.start",
        "title": "LIM: Open Workspace",
        "icon": "$(rocket)"
      }
    ],
    "keybindings": [
      {
        "command": "_lim.ctrlJ",
        "key": "ctrl+j",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u0005" },
        "key": "ctrl+e",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u000b" },
        "key": "ctrl+k",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u000c" },
        "key": "ctrl+l",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "properties": {
        "lim.workspace.browserPort": {
          "type": "number",
          "default": 8765,
          "description": "Port of the LIM browser server (limServer.py)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node_modules/typescript/bin/tsc -p ./",
    "watch": "node_modules/typescript/bin/tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
